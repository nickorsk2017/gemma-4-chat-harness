# Copy to .env and fill in. All agents' LLM/vision calls run through gemma
# (google/gemma-4-31b-it @ https://integrate.api.nvidia.com/v1) — the single
# key below is REQUIRED; there is no mock LLM fallback.
GEMMA_API_KEY=

# --- master_orchestrator ---
# Per-sub-agent budget; keep below the gateway's GATEWAY_ORCHESTRATOR_TIMEOUT_S.
ORCHESTRATOR_SUBAGENT_TIMEOUT_S=120

# --- LangSmith tracing (optional, all agents) ---
# For local (non-docker) runs; in the composed stack docker-compose.yml
# forwards these to the mcp service and stdio sub-agents inherit them.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=gemma-chat
