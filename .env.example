# agent-chat — docker compose overrides. Copy to `.env` and adjust as needed.
# Every value has a safe default baked into docker-compose.yml; this file only
# exists so you can override without editing the compose file.

# --- Host port mappings ---
FRONTEND_PORT=3000
BACKEND_PORT=8000
MCP_PORT=8100

# --- Frontend ---
# Base URL the browser uses to reach the gateway (host-visible).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# --- LLM: gemma via the NVIDIA OpenAI-compatible endpoint ---
# Single key shared by ALL MCP agents (orchestrator, web_agent, doc_analyzer,
# image_analyzer). REQUIRED — there is no mock LLM fallback; agents raise a
# configuration error without it.
GEMMA_API_KEY=

# --- Thread memory (PostgreSQL, LangGraph checkpointer) ---
# Credentials for the compose-managed postgres service; the mcp service derives
# ORCHESTRATOR_DATABASE_URL from them. For local (non-docker) runs set
# ORCHESTRATOR_DATABASE_URL yourself, or leave it unset for the in-memory
# fallback (no cross-restart persistence).
POSTGRES_USER=agent
POSTGRES_PASSWORD=agent
POSTGRES_DB=agent_chat

# --- LangSmith tracing (optional) ---
# Traces every LangChain/LangGraph call from ALL MCP agents (orchestrator,
# web_agent, doc_analyzer, image_analyzer). Leave TRACING=false / key empty
# to disable; no code depends on these being set.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=gemma-chat

# --- Timeout budgets ---
# Per-attempt LLM HTTP timeout for every agent; keep 2x this below
# ORCHESTRATOR_SUBAGENT_TIMEOUT_S so a hung attempt + retry fit the budget.
LLM_REQUEST_TIMEOUT_S=45
# Gateway total budget: planner + slowest sub-agent + synthesis.
GATEWAY_ORCHESTRATOR_TIMEOUT_S=240
